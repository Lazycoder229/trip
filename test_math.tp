# tests/tp/test_math.tp
#
# Same coverage as the original test_modules/test_math.tp, but every value
# is checked against an expected result instead of just being printed for
# a human to eyeball. A regression here throws -> uncaught -> exit code 70
# -> run_tp_tests.sh marks this file FAILED.

import "tests/tp/assert.tp"

assertEq(sqrt(16), 4, "sqrt(16) == 4")
assertEq(pow(2, 10), 1024, "pow(2, 10) == 1024")
assertEq(abs(-5), 5, "abs(-5) == 5")
assertEq(min(3, 1, 4, 1, 5, 9), 1, "min(...) == 1")
assertEq(max(3, 1, 4, 1, 5, 9), 9, "max(...) == 9")
assertEq(floor(3.7), 3, "floor(3.7) == 3")
assertEq(ceil(3.2), 4, "ceil(3.2) == 4")
assertEq(round(3.456, 2), 3.46, "round(3.456, 2) == 3.46")

let dieRoll = randomInt(1, 6)
assertTrue(dieRoll >= 1 and dieRoll <= 6, "randomInt(1, 6) is in range")

# sqrt(-1) should raise, not crash the process -- confirm it's catchable.
let caught = false
try
    sqrt(-1)
catch e
    caught = true
assertTrue(caught, "sqrt(-1) raises a catchable error")

outn("test_math: all assertions passed")
