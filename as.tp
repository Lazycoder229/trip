let results = []

async fn fetch(url)
    let res = await httpGet(url)
    results.append(jsonParse(res["body"]))

spawn fetch("https://jsonplaceholder.typicode.com/posts/1")
spawn fetch("https://jsonplaceholder.typicode.com/posts/2")
spawn fetch("https://jsonplaceholder.typicode.com/posts/3")

# Yield to let the spawned fibers run and complete
waitAll() 
outn(len(results))   # 3