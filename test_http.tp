# ── test_http.tp — HTTP tests using jsonplaceholder.typicode.com ─────────────

# 1. GET a single post
let res = httpGet("https://jsonplaceholder.typicode.com/posts/1")
outn("GET /posts/1 status: " + str(res["status"]))
let post = jsonParse(res["body"])
outn("  title: " + post["title"])
outn("  userId: " + str(post["userId"]))

# 2. GET all posts (returns 100 items)
let res2 = httpGet("https://jsonplaceholder.typicode.com/posts")
outn("GET /posts status: " + str(res2["status"]))
let posts = jsonParse(res2["body"])
outn("  total posts: " + str(posts.len()))

# 3. GET with query-style URL — filter by userId
let res3 = httpGet("https://jsonplaceholder.typicode.com/posts?userId=1")
outn("GET /posts?userId=1 status: " + str(res3["status"]))
let userPosts = jsonParse(res3["body"])
outn("  posts by user 1: " + str(userPosts.len()))

# 4. POST — create a new post
let res4 = httpPost(
    "https://jsonplaceholder.typicode.com/posts",
    {"Content-Type": "application/json"},
    {
        "title": "Hello from Trip!",
        "body": "This post was created by the Trip language HTTP builtin.",
        "userId": 1
    }
)
outn("POST /posts status: " + str(res4["status"]))
let created = jsonParse(res4["body"])
outn("  new post id: " + str(created["id"]))
outn("  title: " + created["title"])

# 5. GET comments for a post
let res5 = httpGet("https://jsonplaceholder.typicode.com/posts/1/comments")
outn("GET /posts/1/comments status: " + str(res5["status"]))
let comments = jsonParse(res5["body"])
outn("  comment count: " + str(comments.len()))
outn("  first commenter email: " + comments[0]["email"])

# 6. GET a user
let res6 = httpGet("https://jsonplaceholder.typicode.com/users/1")
outn("GET /users/1 status: " + str(res6["status"]))
let user = jsonParse(res6["body"])
outn("  name: " + user["name"])
outn("  email: " + user["email"])
outn("  company: " + user["company"]["name"])

outn("HTTP tests done!")
