# strings_fstring.tp
let name = "Alice"
let age  = 30

outn(f"Hello {name}, you are {age} years old")
# Hello Alice, you are 30 years old

outn(f"5 + 5 = {5 + 5}")
# 5 + 5 = 10

# chars.tp
let letter = 'A'
let tab    = '\t'
let quote  = '\''

outn(letter)         # A
outn(type(letter))   # char
outn(ord(letter))    # 65

# closures_counter.tp
fn makeCounter()
    let count = 0
    fn inc()
        count += 1
        return count
    return inc

let c = makeCounter()
outn(c())   # 1
outn(c())   # 2
outn(c())   # 3