# variables.tp
let x = 10          # mutable variable
const PI = 3.14159  # immutable constant

x = 20              # reassign
x += 3              # compound assignment: x is now 23
x++                 # increment:           x is now 24
x--                 # decrement:           x is now 23

outn(x)    # 23
outn(PI)   # 3.14159

